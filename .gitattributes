# Deterministic line-ending policy (v0.6.90 / p243).
# Default: text auto-detect, normalize to LF in the repository.
* text=auto eol=lf

# Explicit LF for public text/source/data formats.
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.svg text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Windows-native command scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets: no text conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.mov binary
